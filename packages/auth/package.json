{
	"name": "@autumn/auth",
	"version": "0.0.1",
	"author": "Autumn",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./utils": {
			"types": "./src/utils/index.ts",
			"import": "./src/utils/index.ts",
			"default": "./src/utils/index.ts"
		},
		"./oauth": {
			"types": "./src/oauth/index.ts",
