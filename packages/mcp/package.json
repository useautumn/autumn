{
  "name": "@autumn/mcp",
  "version": "0.0.1",
  "author": "Speakeasy",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "@autumn/mcp": "bin/mcp-server.js",
    "mcp": "bin/mcp-server.js"
  },
  "scripts": {
    "generate": "speakeasy run -t autumn-mcp -y -o console",
    "build": "bun src/mcp-server/build.mts && tsc",
    "mcpb:build": "bun src/mcp-server/build.mts --pack && tsc",
    "start": "node bin/mcp-server.js start",
    "ts": "tsc --noEmit"
  },
  "dependencies": {
    "@autumn/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stricli/core": "^1.1.2",
    "express": "^5.1.0",
    "zod": "^4.0.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.2.0",
    "@types/bun": "^1.2.13",
    "@types/express": "^5.0.1",
    "@types/node": "^18.19.3",
    "typescript": "~5.8.3"
  }
}
