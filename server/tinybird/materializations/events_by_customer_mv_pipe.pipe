DESCRIPTION >
    Materializes events into events_by_customer_mv for fast customer-scoped listing.
    Copies all event columns without aggregation - just re-sorted by customer.

NODE transformation_node
SQL >
    SELECT
        id,
        org_id,
        env,
        customer_id,
        event_name,
        timestamp,
        value,
        properties,
        idempotency_key,
        coalesce(entity_id, '') as entity_id
    FROM events

TYPE materialized
DATASOURCE events_by_customer_mv
