{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"typeRoots": ["./node_modules/@types", "../node_modules/@types"],
		"types": ["bun", "node"],
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowImportingTsExtensions": true,
		"allowSyntheticDefaultImports": true,
		"paths": {
			"@/*": ["../server/src/*"],
			"@server/*": ["../server/src/*"],
			"@shared/*": ["../shared/*"],
			"@tests/*": ["../server/tests/*"],
			"@api/*": ["../shared/api/*"],
			"@models/*": ["../shared/models/*"],
			"@utils/*": ["../shared/utils/*"],
			"@lua/*": ["../server/src/_luaScripts/*"],
			"@autumn/shared": ["../shared/index.ts"],
			"@autumn/shared/*": ["../shared/*"],
			"autumn-js": ["../packages/autumn-js/src/sdk/index.ts"],
			"autumn-js/backend/hono": ["../packages/autumn-js/src/backend/adapters/hono.ts"],
			"@useautumn/sdk": ["../packages/sdk/src/index.ts"],
			"@useautumn/sdk/*": ["../packages/sdk/src/*"],
			"stripe": ["../node_modules/.bun/node_modules/stripe/esm/stripe.esm.node"],
			"stripe/*": ["../node_modules/.bun/node_modules/stripe/esm/*"]
		}
	},
	"include": ["**/*.ts", "**/*.js"],
	"exclude": ["node_modules", "dist"]
}
