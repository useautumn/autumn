		"@phosphor-icons/react"
	],
	"cssEntry": ".ds-compiled/styles.css",
	"readmeHeader": ".design-sync/conventions.md",
	"overrides": {
		"Dialog": { "cardMode": "single", "viewport": "900x700" },
